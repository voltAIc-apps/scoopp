# Copy to .env and fill in values
# Do NOT commit .env to git

SECRET_KEY=           # JWT signing key (REQUIRED when jwt_enabled=true, app will refuse to start without it)
API_KEY=              # X-API-Key header for /research endpoints

BRAVE_API_KEY=        # Brave Search API key
OPENAI_API_KEY=       # LLM extraction (company field parsing)

MAIL_PROVIDER=brevo   # brevo | sendgrid
MAIL_API_KEY=         # Transactional email API key
MAIL_FROM=            # Sender email address

S3_ENDPOINT=          # S3/MinIO endpoint URL
S3_BUCKET=            # S3 bucket name
S3_ACCESS_KEY=        # S3 access key
S3_SECRET_KEY=        # S3 secret key
